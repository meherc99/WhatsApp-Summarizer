# --- Apify ---
APIFY_API_TOKEN=your_apify_token_here

# Apify actor to use for WhatsApp scraping.
# Find actors at https://apify.com/store — search "WhatsApp".
# The actor must accept chatId + maxMessages in its input schema.
APIFY_ACTOR_ID=extremescrapes/whatsapp-messages-scraper

# Optional: fully override the actor input as a JSON string.
# Use this if the actor expects different input keys than chatId/maxMessages.
# APIFY_ACTOR_INPUT_JSON={"phoneNumber": "+1234567890", "limit": 200}

# --- OpenAI ---
OPENAI_API_KEY=your_openai_key_here

# --- Legacy Selenium (scrape.py — kept for backward compatibility) ---
# FIREFOX_BINARY_PATH=/Applications/Firefox.app/Contents/MacOS/firefox
# FIREFOX_PROFILE=/Users/yourname/Library/Application Support/Firefox/Profiles/xxxxxxxx.default
